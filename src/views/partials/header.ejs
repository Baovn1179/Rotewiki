<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Rotewiki</title>

    <link
        rel="stylesheet"
        href="/bootstrap/css/bootstrap.min.css"
    >

    <link
        rel="stylesheet"
        href="public/css/style.css"
    >

</head>

<body>

<div class="main-layout">

    <!-- Sidebar -->
    <aside class="sidebar">

        <!-- Logo -->
        <div class="logo-box">

            <img
                src="/images/logo.png"
                alt="logo"
                class="logo-img"
            >

            <span class="logo-text">
                Rotewiki
            </span>

        </div>

        <!-- Menu -->
        <ul class="menu-list">

            <li>
                <a href="/">
                    <i class="bi bi-house"></i>

                    <span>Trang chủ</span>
                </a>
            </li>

            <li>
                <a href="/login">
                    <i class="bi bi-person"></i>

                    <span>Đăng nhập</span>
                </a>
            </li>

            <li>
                <a href="#">
                    <i class="bi bi-person-plus"></i>

                    <span>Đăng ký</span>
                </a>
            </li>

        </ul>

        <!-- Notification -->
        <div class="sidebar-notify">

            <p>
                🔔 Chào mừng đến với Rotewiki
            </p>

        </div>

    </aside>

    <!-- Main content -->
    <main class="content-area">