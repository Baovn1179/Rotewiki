
<%- include("../partials/header") %>

<div class="register-page">

    <!-- TOP HEADER -->
    <div
        class="register-top"
        onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
    >

        <h1>
            Yêu cầu xét duyệt hồ sơ cộng tác viên
        </h1>

        <div class="register-top-divider"></div>

    </div>

    <!-- MAIN BOX -->
    <div class="register-container">

        <!-- Intro -->
        <div class="register-intro">

            <h2>
                Chào mừng đồng chí đến với Rotewiki!
            </h2>

            <h4>
                Đây là trang wiki, cơ quan chính luận của CLB Rotesovie.
                Hãy cộng tác với chúng tôi, vì một tương lai tươi đẹp của chủ nghĩa cộng sản!
            </h4>

        </div>

        <!-- GROUP 1 -->
        <div class="register-group">

            <div class="group-title">
                Thông tin tài khoản
            </div>

            <div class="form-group-custom">

                <label>Username</label>
                <input type="text">

            </div>

            <div class="form-group-custom">

                <label>Email</label>
                <input type="email">

            </div>

            <div class="form-group-custom">

                <label>Password</label>
                <input type="password">

            </div>

            <div class="form-group-custom">

                <label>Nhập lại password</label>
                <input type="password">

            </div>

            <div class="form-group-custom">

                <label>Hình thức cộng tác</label>

                <select>

                    <option>
                        Cộng tác viên chính luận
                    </option>

                </select>

            </div>

        </div>

        <!-- GROUP 2 -->
        <div class="register-group">

            <div class="group-title">
                Câu hỏi xét duyệt
            </div>

            <h1 class="coming-soon">
                Đang cập nhật
            </h1>

            <textarea
                class="review-textbox"
                placeholder="Nhập câu trả lời..."
            ></textarea>

        </div>

        <!-- GROUP 3 -->
        <div class="register-group">

            <div class="group-title">
                Chính sách cộng đồng
            </div>

            <div class="checkbox-group">

                <input type="checkbox">
                <span>
                    Tôi đồng ý với chính sách cộng đồng
                </span>

            </div>

            <div class="checkbox-group">

                <input type="checkbox">
                <span>
                    Tôi đồng ý tham gia
                </span>

            </div>

        </div>

        <!-- BUTTON -->
        <div class="submit-wrapper">

            <button class="submit-register-btn">

                Gửi hồ sơ xét duyệt

            </button>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>
