<%- include('../partials/user/header') %>

<div class="container-fluid py-4">

    <h1 class="mb-4 fw-bold">
        Trang Chủ Blog
    </h1>

    <div class="row g-4">

        <% posts.forEach(post => { %>

            <div class="col-md-4">

                <div class="card custom-card h-100">

                    <div class="card-body">

                        <h3 class="card-title">
                            <%= post.title %>
                        </h3>

                        <p class="text-muted">
                            <%= post.desc %>
                        </p>

                        <button class="btn btn-dark">
                            Xem thêm
                        </button>

                    </div>

                </div>

            </div>

        <% }) %>

    </div>

</div>

<%- include('../partials/user/footer') %>