<%- include('../partials/admin/header') %>

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Quản lý Người dùng</h1>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUserModal">
            <i class="bi bi-plus-circle"></i> Thêm người dùng
        </button>
    </div>

    <!-- Search & Filter -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form class="row g-3" id="filterForm">
                <div class="col-12 col-md-6">
                    <input type="text" class="form-control" id="searchInput" placeholder="Tìm theo tên hoặc username...">
                </div>
                <div class="col-12 col-md-4">
                    <select class="form-select" id="roleFilter">
                        <option value="">Tất cả vai trò</option>
                        <option value="admin">Admin</option>
                        <option value="ctv">Cộng tác viên</option>
                        <option value="user">Người dùng</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <button type="reset" class="btn btn-secondary w-100">
                        <i class="bi bi-arrow-clockwise"></i> Đặt lại
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Pending Approval Table -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h2 class="h5 mb-0">Danh sách chờ xét duyệt</h2>
                <p class="text-muted mb-0">Các thành viên có trạng thái chưa được kích hoạt.</p>
            </div>
            <span class="badge bg-warning text-dark">Tổng: <%= (pendingUsers && pendingUsers.length) || 0 %></span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Username</th>
                        <th>Họ và Tên</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody id="pendingTableBody">
                    <% if (pendingUsers && pendingUsers.length > 0) { %>
                        <% pendingUsers.forEach(user => { %>
                            <tr data-username="<%= user.username %>">
                                <td><code><%= user.username %></code></td>
                                <td><%= user.fullname || 'Chưa cập nhật' %></td>
                                <td>
                                    <span class="badge bg-<%= user.role === 'admin' ? 'danger' : user.role === 'ctv' ? 'info' : 'secondary' %>">
                                        <%= user.role || 'user' %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark">Chưa duyệt</span>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-info view-review-btn" data-username="<%= user.username %>">
                                        <i class="bi bi-eye"></i> Xem hồ sơ
                                    </button>
                                    <button type="button" class="btn btn-sm btn-success approve-user-btn" data-username="<%= user.username %>">
                                        <i class="bi bi-check-circle"></i> Duyệt
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Hiện chưa có hồ sơ chờ xét duyệt.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Users Table (Desktop) -->
    <div class="card shadow-sm d-none d-md-block">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Username</th>
                        <th>Họ và Tên</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                    <% if (users && users.length > 0) { %>
                        <% users.forEach(user => { %>
                            <tr data-username="<%= user.username %>">
                                <td>
                                    <code><%= user.username %></code>
                                </td>
                                <td><%= user.fullname || 'Chưa cập nhật' %></td>
                                <td>
                                    <span class="badge bg-<%= user.role === 'admin' ? 'danger' : user.role === 'ctv' ? 'info' : 'secondary' %>">
                                        <%= user.role || 'user' %>
                                    </span>
                                </td>
                                <td>
                                    <% if (user.isactive) { %>
                                        <span class="badge bg-success">Hoạt động</span>
                                    <% } else { %>
                                        <span class="badge bg-warning text-dark">Chưa kích hoạt</span>
                                    <% } %>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-info" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="btn btn-sm btn-warning" title="Chỉnh sửa">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Không có người dùng nào
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Users Cards (Mobile) -->
    <div class="d-md-none" id="userCardContainer">
        <% if (users && users.length > 0) { %>
            <% users.forEach(user => { %>
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <div class="row align-items-start">
                            <div class="col">
                                <h6 class="card-title mb-1">
                                    <code><%= user.username %></code>
                                </h6>
                                <p class="text-muted mb-2 small">
                                    <%= user.fullname || 'Chưa cập nhật' %>
                                </p>
                                <div class="mb-2">
                                    <span class="badge bg-<%= user.role === 'admin' ? 'danger' : user.role === 'ctv' ? 'info' : 'secondary' %>">
                                        <%= user.role || 'user' %>
                                    </span>
                                    <span class="badge bg-<%= user.isactive ? 'success' : 'warning text-dark' %>">
                                        <%= user.isactive ? 'Hoạt động' : 'Chưa duyệt' %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn btn-sm btn-info flex-grow-1">
                                <i class="bi bi-eye"></i> Xem
                            </button>
                            <button class="btn btn-sm btn-warning flex-grow-1">
                                <i class="bi bi-pencil"></i> Sửa
                            </button>
                            <button class="btn btn-sm btn-danger flex-grow-1">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="alert alert-info text-center">
                <i class="bi bi-info-circle"></i> Không có người dùng nào
            </div>
        <% } %>
    </div>

</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thêm người dùng mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addUserForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" name="username" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Họ và tên</label>
                        <input type="text" class="form-control" name="fullname" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu</label>
                        <input type="password" class="form-control" name="password" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vai trò</label>
                        <select class="form-select" name="role" required>
                            <option value="user">Người dùng</option>
                            <option value="ctv">Cộng tác viên</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Thêm</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Review Detail Modal -->
<div class="modal fade" id="reviewDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chi tiết hồ sơ xét duyệt</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <strong>Username:</strong>
                    <span id="modalUsername"></span>
                </div>
                <div class="mb-3">
                    <strong>Họ và tên:</strong>
                    <span id="modalFullname"></span>
                </div>
                <div class="mb-3">
                    <strong>Vai trò:</strong>
                    <span id="modalRole"></span>
                </div>
                <div class="mb-3">
                    <strong>Thông tin trả lời:</strong>
                    <pre id="modalQuestionRecord" class="p-3 bg-light rounded" style="white-space: pre-wrap; word-break: break-word;"></pre>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" id="approveFromModalBtn" class="btn btn-success">Duyệt thành viên</button>
            </div>
        </div>
    </div>
</div>

<style>
    .table-responsive {
        border-radius: 0.375rem;
    }
    
    .badge {
        font-size: 0.8rem;
        padding: 0.4rem 0.6rem;
    }
    
    .btn-sm {
        padding: 0.35rem 0.65rem;
        font-size: 0.85rem;
    }
    
    @media (max-width: 768px) {
        .card {
            border: 1px solid #e9ecef;
        }
        
        .card-body {
            padding: 1rem;
        }
    }
</style>

<script src="/public/js/admin-usermanage.js"></script>

<%- include('../partials/admin/footer') %>
